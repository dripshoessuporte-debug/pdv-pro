# String de conexão PostgreSQL (Neon/Supabase/Render etc.)
DATABASE_URL=

# Porta HTTP do backend Express
PORT=3000

# Ambiente de execução (development | production)
NODE_ENV=development

# Nível de logs do backend (debug | info | warn | error)
LOG_LEVEL=info

# Chave da API OpenRouteService usada somente no backend
OPENROUTESERVICE_API_KEY=

# Chave obrigatória para inbound externo (/integrations/orders/inbound)
INTEGRATION_API_KEY=

# Chave administrativa geral para ações sensíveis
ADMIN_API_KEY=

# Chave administrativa para rotas destrutivas de desenvolvimento
ADMIN_RESET_KEY=

# Habilita rotas /dev/* (somente desenvolvimento)
ENABLE_DEV_ROUTES=false

# Base path opcional do frontend (build/deploy)
BASE_PATH=

# Variável de ambiente do Replit para contexto local
REPL_ID=

# Tokens da Focus NFe (HTTP Basic Auth: token como usuário e senha em branco)
FOCUS_NFE_HOMOLOGATION_TOKEN=
FOCUS_NFE_PRODUCTION_TOKEN=
FOCUS_NFE_TIMEOUT_MS=15000
